# ---- GCP / Vertex AI ----
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=europe-west4
GCP_SERVICE_ACCOUNT_FILE=/path/to/service-account.json

# MedGemma dedicated endpoint
MEDGEMMA_ENDPOINT_ID=mg-endpoint-a99f3d06-...
MEDGEMMA_DEDICATED_DOMAIN=mg-endpoint-a99f3d06-....europe-west4-93621104296.prediction.vertexai.goog

# ---- External APIs ----
# Search priority: Google CSE → Serper → DuckDuckGo (free fallback)
GOOGLE_SEARCH_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-custom-search-engine-id
SERPER_API_KEY=your-serper-key

# ---- Infrastructure ----
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/medsecondopinion
REDIS_URL=redis://localhost:6379/0
GCS_BUCKET=medsecondopinion-reports

# ---- App Settings ----
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Pipeline Tuning ----
MEDGEMMA_MAX_TOKENS=4096
MEDGEMMA_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.3
SERPER_RESULTS_PER_QUERY=5
STORM_SEARCH_TOP_K=20
STORM_TIMEOUT_SECONDS=180
PIPELINE_TIMEOUT_SECONDS=300
